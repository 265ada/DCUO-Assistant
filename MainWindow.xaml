<Window x:Class="DCUOTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DCUO Assistant"
        Height="620" Width="820"
        MinHeight="500" MinWidth="700"
        WindowStyle="SingleBorderWindow"
        Background="#1a1a2e">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#00d4ff"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#00d4ff"/>
            <Setter Property="BorderBrush" Value="#00d4ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Image Source="pack://application:,,,/dcuo-qol.ico"
                   Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,8,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="DCUO ASSISTANT" FontSize="20" FontWeight="Bold"
                       Foreground="#00d4ff" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="● WATCHING" FontSize="11"
                       Foreground="#00ff88" Margin="16,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Session Stats Row -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,8">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="SESSION NTH DROPS" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="SessionDropCount" Text="0" Style="{StaticResource ValueText}"
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="SESSION NTH XP" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="SessionXp" Text="0" Style="{StaticResource ValueText}"
                               FontSize="28" FontWeight="Bold" Foreground="#ffd700"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="ALL TIME NTH DROPS" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="AllTimeDropCount" Text="0" Style="{StaticResource ValueText}"
                               FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="ALL TIME NTH XP" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="AllTimeXp" Text="0" Style="{StaticResource ValueText}"
                               FontSize="28" FontWeight="Bold" Foreground="#ffd700"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="LAST DROP" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="LastDropText" Text="—" Style="{StaticResource ValueText}"
                               FontSize="13" FontWeight="Bold" Foreground="#ff6b35" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Source Marks / Ally Favors / Exobytes Row -->
        <UniformGrid Grid.Row="2" Columns="5" Margin="0,0,0,8">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="SOURCE MARKS" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="SessionSourceMarks" Text="0" Style="{StaticResource ValueText}"
                               FontSize="24" FontWeight="Bold" Foreground="#a78bfa"/>
                    <TextBlock x:Name="AllTimeSourceMarks" Text="0 all time" Foreground="#666" FontSize="10"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="ALLY FAVORS" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="SessionAllyFavors" Text="0" Style="{StaticResource ValueText}"
                               FontSize="24" FontWeight="Bold" Foreground="#34d399"/>
                    <TextBlock x:Name="AllTimeAllyFavors" Text="0 all time" Foreground="#666" FontSize="10"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="EXOBYTES" Style="{StaticResource HeaderText}" FontSize="10" Margin="0,0,0,3"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Standard"  Foreground="#888888" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ExoStandard"  Text="0" Foreground="#888888" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Flawed"    Foreground="#f87171" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ExoFlawed"    Text="0" Foreground="#f87171" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Solid"     Foreground="#4fc3f7" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ExoSolid"     Text="0" Foreground="#4fc3f7" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Pristine"  Foreground="#34d399" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ExoPristine"  Text="0" Foreground="#34d399" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Flawless"  Foreground="#c084fc" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ExoFlawless"  Text="0" Foreground="#c084fc" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Timeless"  Foreground="#fbbf24" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ExoTimeless"  Text="0" Foreground="#fbbf24" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Perfected" Foreground="#00d4ff" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="ExoPerfected" Text="0" Foreground="#00d4ff" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>

                        <Border Grid.Row="7" Grid.ColumnSpan="2" BorderBrush="#333" BorderThickness="0,1,0,0" Margin="0,2,0,1"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Total"     Foreground="#555"   FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="ExoTotal"     Text="0" Foreground="#aaaaaa" FontSize="12" FontWeight="Bold" FontFamily="Consolas" TextAlignment="Right"/>
                    </Grid>
                    <TextBlock x:Name="AllTimeExobytes" Text="0 all time" Foreground="#555" FontSize="9" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="LAST ITEM" Style="{StaticResource HeaderText}" FontSize="10"/>
                    <TextBlock x:Name="LastItemText" Text="—" Style="{StaticResource ValueText}"
                               FontSize="11" FontWeight="Bold" Foreground="#fb923c" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
                    <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="ALLIANCE" Style="{StaticResource HeaderText}" FontSize="10" Margin="0,0,0,4"/>
                    <!-- Rare = Blue, Epic = Purple, Legendary = Yellow -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Rare" Foreground="#4fc3f7" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center" Width="60"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AllianceRare" Text="0" Foreground="#4fc3f7" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Epic" Foreground="#c084fc" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center" Width="60"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AllianceEpic" Text="0" Foreground="#c084fc" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Legendary" Foreground="#fbbf24" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center" Width="60"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="AllianceLegendary" Text="0" Foreground="#fbbf24" FontSize="16" FontWeight="Bold" FontFamily="Consolas"/>
                    </Grid>
                    <TextBlock x:Name="AllTimeAlliance" Text="0 all time" Foreground="#666" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>        </UniformGrid>

        <!-- Metal Type Breakdown -->
        <Border Grid.Row="3" Background="#16213e" CornerRadius="8" Padding="12" Margin="4,0,4,8">
            <StackPanel>
                <TextBlock Text="SESSION BREAKDOWN BY TYPE" Style="{StaticResource HeaderText}"
                           FontSize="10" Margin="0,0,0,8"/>
                <UniformGrid Columns="6">
                    <StackPanel Margin="4,0">
                        <TextBlock Text="RAW" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CountRaw" Text="0" Foreground="#aaaaaa"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="EXTRACTED" Foreground="#4fc3f7" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CountExtracted" Text="0" Foreground="#4fc3f7"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="TREATED" Foreground="#81c784" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CountTreated" Text="0" Foreground="#81c784"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="PROCESSED" Foreground="#ffb74d" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CountProcessed" Text="0" Foreground="#ffb74d"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="REFINED" Foreground="#f06292" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CountRefined" Text="0" Foreground="#f06292"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="PURIFIED" Foreground="#ffd700" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CountPurified" Text="0" Foreground="#ffd700"
                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- Drop Log -->
        <Border Grid.Row="4" Background="#16213e" CornerRadius="8" Margin="4,0,4,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="DROP LOG" Style="{StaticResource HeaderText}"
                           FontSize="10" Margin="12,8"/>
                <DataGrid x:Name="DropGrid" Grid.Row="1"
                          Background="Transparent" BorderThickness="0"
                          RowBackground="#1a1a2e" AlternatingRowBackground="#16213e"
                          Foreground="#cccccc" FontFamily="Consolas" FontSize="12"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#0f3460"
                          CanUserResizeRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time"      Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="70"/>
                        <DataGridTextColumn Header="Character" Binding="{Binding Character}"  Width="120"/>
                        <DataGridTextColumn Header="Type"      Binding="{Binding MetalType}"  Width="100"/>
                        <DataGridTextColumn Header="Qty"       Binding="{Binding Quantity}"   Width="50"/>
                        <DataGridTextColumn Header="XP"        Binding="{Binding XpValue}"    Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Chat Tools Row (inline preview + popout button) -->
        <Grid Grid.Row="5" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#16213e" CornerRadius="8" Padding="10,8" Margin="4,0,4,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CHAT" Foreground="#00d4ff" FontSize="10"
                               FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ProgressBar Grid.Column="1" x:Name="CharProgressBar"
                                 Minimum="0" Maximum="60" Value="0"
                                 Height="8" VerticalAlignment="Center"
                                 Foreground="#00ff88" Background="#0f3460"/>
                    <TextBlock Grid.Column="2" x:Name="CharCountLabel"
                               Text="0 / 60" Foreground="#00ff88"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                               VerticalAlignment="Center" Margin="10,0,0,0" Width="55"/>
                    <!-- LFG inline -->
                    <Border Grid.Column="3" x:Name="LfgPanel" Background="#0f3460" CornerRadius="6"
                            Padding="8,2" Margin="8,0,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LFG" Foreground="#00d4ff" FontSize="9"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="LfgTimerLabel" Text="60s" Foreground="#00d4ff"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                                       VerticalAlignment="Center" Width="34"/>
                        </StackPanel>
                    </Border>
                    <!-- Popout button -->
                    <Button Grid.Column="4" Content="⬡" ToolTip="Pop out chat overlay"
                            Style="{StaticResource ActionButton}" FontSize="12"
                            Margin="8,0,0,0" Padding="6,2" Click="PopoutChat_Click"/>
                </Grid>
            </Border>

            <!-- Always On Top toggle -->
            <Button Grid.Column="1" x:Name="AlwaysOnTopBtn" Content="📌 ON TOP"
                    Style="{StaticResource ActionButton}" Margin="0,0,4,0"
                    Click="AlwaysOnTop_Click"/>
        </Grid>

        <!-- Bottom Controls -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="4,0">
            <Button x:Name="ClearSessionBtn" Content="Clear Session" Style="{StaticResource ActionButton}"
                    Margin="0,0,8,0" Click="ClearSession_Click"/>
            <Button x:Name="ViewAllBtn" Content="View All Time" Style="{StaticResource ActionButton}"
                    Margin="0,0,8,0" Click="ViewAll_Click"/>
            <Button x:Name="SoundToggleBtn" Content="🔊 Sound ON" Style="{StaticResource ActionButton}"
                    Margin="0,0,8,0" Click="SoundToggle_Click"/>
            <Button x:Name="SelectRegionBtn" Content="🎯 Select Chat Region" Style="{StaticResource ActionButton}"
                    Margin="0,0,8,0" Click="SelectRegion_Click"/>
            <TextBlock x:Name="RegionStatus" Text="No region set" Foreground="#555" FontSize="10"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="LogPathText" Text="" Foreground="#555" FontSize="10"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>













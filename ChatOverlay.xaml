<Window x:Class="DCUOTracker.ChatOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat Overlay"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Left="100" Top="100">

    <Window.Resources>
        <Style x:Key="TinyBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#00d4ff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="3,1"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#CC1a1a2e"
            CornerRadius="8"
            BorderBrush="#00d4ff"
            BorderThickness="1"
            MouseDown="Border_MouseDown">

        <StackPanel x:Name="MainStack" Margin="8,6,8,6">

            <!-- Title bar -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="⚡ CHAT" Foreground="#00d4ff"
                           FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>

                <!-- LFG Mode toggle -->
                <Button Grid.Column="1" x:Name="LfgModeBtn" Content="LFG"
                        Style="{StaticResource TinyBtn}"
                        ToolTip="LFG Channel Mode — timer fires on every Enter press"
                        Click="LfgMode_Click" FontSize="9"
                        Foreground="#555555"/>

                <!-- Vertical/Horizontal toggle -->
                <Button Grid.Column="2" x:Name="OrientBtn" Content="⇅"
                        Style="{StaticResource TinyBtn}"
                        ToolTip="Toggle vertical/horizontal"
                        Click="Orient_Click" FontSize="12"/>

                <!-- Pin -->
                <Button Grid.Column="3" x:Name="PinBtn" Content="📌"
                        Style="{StaticResource TinyBtn}"
                        ToolTip="Always on Top" Click="Pin_Click"/>

                <!-- Close -->
                <Button Grid.Column="4" Content="✕"
                        Style="{StaticResource TinyBtn}"
                        Foreground="#ff4444" Click="Close_Click"/>
            </Grid>

            <!-- ═══ HORIZONTAL LAYOUT ═══ -->
            <Grid x:Name="HorizontalLayout" Visibility="Visible" MinWidth="200">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Char bar -->
                <ProgressBar Grid.Column="0" x:Name="CharBarH"
                             Minimum="0" Maximum="60" Value="0"
                             Height="6" VerticalAlignment="Center"
                             Foreground="#00ff88" Background="#0f3460"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="1" x:Name="CharLabelH"
                           Text="0/60" Foreground="#00ff88"
                           FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                           Margin="6,0,0,0" VerticalAlignment="Center" Width="36"/>

                <!-- LFG separator -->
                <Border Grid.Column="2" x:Name="LfgSepH"
                        Width="1" Background="#00d4ff" Margin="8,0" Visibility="Collapsed"/>

                <!-- LFG horizontal -->
                <StackPanel Grid.Column="3" x:Name="LfgPanelH"
                            Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="LFG" Foreground="#00d4ff" FontSize="9"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ProgressBar x:Name="LfgBarH" Minimum="0" Maximum="60" Value="60"
                                 Width="50" Height="6" VerticalAlignment="Center"
                                 Foreground="#00d4ff" Background="#0f3460" BorderThickness="0"/>
                    <TextBlock x:Name="LfgLabelH" Text="60s" Foreground="#00d4ff"
                               FontSize="10" FontWeight="Bold" FontFamily="Consolas"
                               Margin="4,0,0,0" VerticalAlignment="Center" Width="30"/>
                </StackPanel>
            </Grid>

            <!-- ═══ VERTICAL LAYOUT ═══ -->
            <StackPanel x:Name="VerticalLayout" Visibility="Collapsed" Width="90">

                <!-- Char label -->
                <TextBlock x:Name="CharLabelV" Text="0 / 60"
                           Foreground="#00ff88" FontSize="13" FontWeight="Bold"
                           FontFamily="Consolas" HorizontalAlignment="Center"
                           Margin="0,0,0,3"/>
                <!-- Char bar vertical (rotated progress) -->
                <ProgressBar x:Name="CharBarV"
                             Minimum="0" Maximum="60" Value="0"
                             Height="8" Foreground="#00ff88"
                             Background="#0f3460" BorderThickness="0"
                             Margin="0,0,0,6"/>

                <!-- LFG vertical -->
                <StackPanel x:Name="LfgPanelV" Visibility="Collapsed">
                    <Border Height="1" Background="#00d4ff" Margin="0,0,0,4"/>
                    <TextBlock Text="LFG" Foreground="#00d4ff" FontSize="9"
                               FontWeight="Bold" HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>
                    <TextBlock x:Name="LfgLabelV" Text="60s"
                               Foreground="#00d4ff" FontSize="16" FontWeight="Bold"
                               FontFamily="Consolas" HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>
                    <ProgressBar x:Name="LfgBarV" Minimum="0" Maximum="60" Value="60"
                                 Height="6" Foreground="#00d4ff"
                                 Background="#0f3460" BorderThickness="0"/>
                </StackPanel>

            </StackPanel>

        </StackPanel>
    </Border>
</Window>

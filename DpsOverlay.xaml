<Window x:Class="DCUOTracker.DpsOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DPS" Width="290"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Left="20" Top="200">

    <Border x:Name="RootBorder" Background="#E6050A18" CornerRadius="8"
            BorderBrush="#00d4ff" BorderThickness="1"
            MouseDown="Border_MouseDown">
        <StackPanel Margin="8,6,8,8">

            <!-- Title bar -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="FightLabel"
                           Text="⚔ NO FIGHT" Foreground="#00d4ff"
                           FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="PinBtn" Content="📌"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#00d4ff" FontSize="10" Cursor="Hand"
                        Padding="3,1" Click="Pin_Click"/>
                <Button Grid.Column="2" Content="✕"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#ff4444" FontSize="10" Cursor="Hand"
                        Padding="3,1" Click="Close_Click"/>
            </Grid>

            <!-- Stats bar -->
            <StackPanel x:Name="StatsPanel" Visibility="Collapsed">
                <TextBlock x:Name="TotalDmgLabel" Text="0"
                           Foreground="#ffd700" FontSize="22" FontWeight="Bold"
                           FontFamily="Consolas" HorizontalAlignment="Center"/>
                <Grid Margin="0,1,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="MaxHitLabel" Text="Max: —"
                               Foreground="#888" FontSize="9"/>
                    <TextBlock Grid.Column="1" x:Name="DurationLabel" Text="0:00"
                               Foreground="#888" FontSize="9" HorizontalAlignment="Right"/>
                </Grid>
                <Border BorderBrush="#222" BorderThickness="0,1,0,0" Margin="0,0,0,4"/>
            </StackPanel>

            <!-- MY PERFORMANCE strip (selected player) -->
            <Border x:Name="MyStatsPanel" Visibility="Collapsed"
                    Background="#101A33" CornerRadius="6" Padding="7,5" Margin="0,0,0,6"
                    BorderBrush="#1E2A44" BorderThickness="1">
                <StackPanel>
                    <!-- DPS + Burst big numbers -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DPS (SUSTAINED)" Foreground="#5A6B85"
                                       FontSize="7.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="MyDpsLabel" Text="0" Foreground="#FFD700"
                                       FontSize="18" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="BURST (BEST 10s)" Foreground="#5A6B85"
                                       FontSize="7.5" FontWeight="Bold" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="MyBurstLabel" Text="0" Foreground="#FF8A3D"
                                       FontSize="18" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>

                    <!-- Metric chips: Activity (graded) | Crit | APM -->
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border x:Name="MyActivityGradeBox" CornerRadius="3" Padding="3,0"
                                    Background="#9CA3AF" VerticalAlignment="Center" Margin="0,0,4,0">
                                <TextBlock x:Name="MyActivityGrade" Text="—" Foreground="Black"
                                           FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="ACTIVITY" Foreground="#5A6B85" FontSize="7" FontWeight="Bold"/>
                                <TextBlock x:Name="MyActivityLabel" Text="—" Foreground="White"
                                           FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="CRIT" Foreground="#5A6B85" FontSize="7" FontWeight="Bold"/>
                            <TextBlock x:Name="MyCritLabel" Text="—" Foreground="#34D399"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="APM" Foreground="#5A6B85" FontSize="7" FontWeight="Bold"/>
                            <TextBlock x:Name="MyApmLabel" Text="—" Foreground="#60A5FA"
                                       FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                    </Grid>

                    <!-- Might / Super / Precision split bar -->
                    <Canvas x:Name="SplitCanvas" Height="7" Margin="0,6,0,2" Background="#0D1525">
                        <Rectangle x:Name="MightSeg"  Canvas.Left="0" Height="7" Fill="#FF6B35"/>
                        <Rectangle x:Name="SuperSeg"  Height="7" Fill="#FBBF24"/>
                        <Rectangle x:Name="PrecSeg"   Height="7" Fill="#9CA3AF"/>
                    </Canvas>
                    <TextBlock x:Name="MySplitLabel" Text="" Foreground="#7A8AA5"
                               FontSize="7.5" FontFamily="Consolas" HorizontalAlignment="Center"/>

                    <!-- Personal best vs current parse -->
                    <TextBlock x:Name="MyBestLabel" Text="" FontSize="9" FontWeight="Bold"
                               FontFamily="Consolas" HorizontalAlignment="Center"
                               Foreground="#FFD24A" Margin="0,4,0,0"/>

                    <!-- Live coach tip -->
                    <Border x:Name="CoachBox" CornerRadius="4" Padding="7,5" Margin="0,6,0,0"
                            Background="#0D1525" BorderThickness="0,0,0,2" BorderBrush="#7CFC00">
                        <StackPanel>
                            <TextBlock x:Name="CoachLabel" Text="COACH" Foreground="#7CFC00"
                                       FontSize="8" FontWeight="Bold" FontFamily="Consolas"/>
                            <TextBlock x:Name="CoachText" Text="" Foreground="#C7D4E6"
                                       FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Player leaderboard -->
            <ItemsControl x:Name="PlayerList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent" BorderThickness="0"
                                Padding="0" Cursor="Hand"
                                Click="PlayerRow_Click" Tag="{Binding}">
                            <Grid Margin="0,1,0,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="38"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Power type icon -->
                                    <TextBlock Grid.Column="0" Text="{Binding PowerIcon}"
                                               FontSize="11" VerticalAlignment="Center"
                                               Margin="0,0,3,0" Visibility="{Binding PowerIconVis}"/>
                                    <!-- Role icon -->
                                    <TextBlock Grid.Column="1" Text="{Binding RoleIcon}"
                                               FontSize="10" VerticalAlignment="Center"
                                               Foreground="{Binding RoleColor}"
                                               Margin="0,0,4,0" Visibility="{Binding RoleIconVis}"/>
                                    <!-- Player name + CR -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White" FontSize="11"
                                                   FontWeight="Bold" FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding CRLabel}"
                                                   Foreground="#555" FontSize="8"
                                                   FontFamily="Consolas"
                                                   Visibility="{Binding CRVis}"/>
                                    </StackPanel>
                                    <!-- DPS -->
                                    <TextBlock Grid.Column="3" Text="{Binding DpsLabel}"
                                               Foreground="{Binding BarColor}"
                                               FontSize="10" FontFamily="Consolas"
                                               Margin="4,0" VerticalAlignment="Center"/>
                                    <!-- % -->
                                    <TextBlock Grid.Column="4" Text="{Binding PctLabel}"
                                               Foreground="#aaa" FontSize="10"
                                               FontFamily="Consolas" TextAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <!-- Bar -->
                                <Grid Grid.Row="1" Background="#111827">
                                    <Rectangle HorizontalAlignment="Left"
                                               Width="{Binding BarWidth}"
                                               Fill="{Binding BarColor}" Opacity="0.75"
                                               Height="4" RadiusX="2" RadiusY="2"/>
                                </Grid>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Ability breakdown -->
            <StackPanel x:Name="AbilityPanel" Visibility="Collapsed" Margin="0,5,0,0">
                <Border BorderBrush="#222" BorderThickness="0,1,0,0" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="AbilityPowerIcon" Text=""
                               FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" x:Name="AbilityPlayerLabel"
                               Text="POWERS" Foreground="#00d4ff"
                               FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="✕" Click="CloseAbility_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#555" FontSize="9" Cursor="Hand" Padding="2,0"/>
                </Grid>
                <ItemsControl x:Name="AbilityList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row: name + stats -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Efficiency dot — bright colored -->
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="{Binding BarColor}"
                                             VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="White" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                        </Ellipse.Effect>
                                    </Ellipse>

                                    <!-- Ability name — bright white, readable -->
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               Foreground="White" FontSize="10"
                                               FontFamily="Consolas" FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>

                                    <!-- Avg hit -->
                                    <TextBlock Grid.Column="2" Text="{Binding AvgLabel}"
                                               Foreground="#8AAABB" FontSize="9"
                                               FontFamily="Consolas" TextAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <!-- Total damage — colored by efficiency -->
                                    <TextBlock Grid.Column="3" Text="{Binding TotalLabel}"
                                               Foreground="{Binding BarColor}"
                                               FontSize="10" FontWeight="Bold"
                                               FontFamily="Consolas" TextAlignment="Right"
                                               VerticalAlignment="Center" Margin="2,0"/>

                                    <!-- % share — bright -->
                                    <TextBlock Grid.Column="4" Text="{Binding PctLabel}"
                                               Foreground="#CCCCCC" FontSize="10"
                                               FontFamily="Consolas" TextAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Damage bar — proportional width + crit/hits label floating right -->
                                <Grid Grid.Row="1" Background="#0D1525" Height="11">
                                    <Rectangle HorizontalAlignment="Left" VerticalAlignment="Center"
                                               Width="{Binding BarWidth}"
                                               Fill="{Binding BarColor}"
                                               Height="5" RadiusX="2" RadiusY="2"
                                               Opacity="0.85"/>
                                    <TextBlock Text="{Binding CritLabel}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Foreground="#90A0BD" FontSize="7.5"
                                               FontFamily="Consolas" Margin="0,0,3,0"/>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>

